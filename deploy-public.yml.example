# SETUP (do this once per new project)
# ─────────────────────────────────────────────────────────────────
# 1. Create a Fine-grained PAT on GitHub:
#      Settings → Developer settings → Personal access tokens → Fine-grained tokens
#      Resource owner : ipatavatsizz
#      Repository     : ipatavatsizz/dw-releases (only)
#      Permission     : Contents → Read and write
#
# 2. Add secret to THIS private repo:
#      Settings → Secrets and variables → Actions → New repository secret
#      Name   : PUBLIC_REPO_PAT
#      Value  : <paste PAT from step 1>
# ─────────────────────────────────────────────────────────────────

name: Sync to dw-releases

on:
  push:
    branches:
      - main
      - develop
    paths:
      - 'README.md'
      - 'release-notes/**'
      - 'assets/**'
  workflow_dispatch:

env:
  REPO_NAME: ${{ github.event.repository.name }}
  RELEASES_REPO: ${{ github.repository_owner }}/dw-releases

jobs:
  sync:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout private repo
        uses: actions/checkout@v4
        with:
          path: private-repo

      - name: Checkout dw-releases
        uses: actions/checkout@v4
        with:
          repository: ${{ env.RELEASES_REPO }}
          token: ${{ secrets.PUBLIC_REPO_PAT }}
          path: dw-releases

      - name: Sync files
        run: |
          mkdir -p dw-releases/$REPO_NAME/assets
          mkdir -p dw-releases/$REPO_NAME/release-notes

          # README
          cp private-repo/README.md dw-releases/$REPO_NAME/README.md 2>/dev/null || true

          # assets/ — sync with delete so removed files are cleaned up
          if [ -d "private-repo/assets" ]; then
            rsync -a --delete private-repo/assets/ dw-releases/$REPO_NAME/assets/
          fi

          # release-notes/ — sync with delete so removed/renamed files are cleaned up
          if [ -d "private-repo/release-notes" ]; then
            rsync -a --delete private-repo/release-notes/ dw-releases/$REPO_NAME/release-notes/
          fi

          # workflow example in public repo root
          cp private-repo/.github/workflows/deploy-public.yml dw-releases/deploy-public.yml.example || true

      - name: Push to dw-releases
        env:
          GITHUB_TOKEN: ${{ secrets.PUBLIC_REPO_PAT }}
        run: |
          cd dw-releases

          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"

          git add $REPO_NAME/ deploy-public.yml.example

          if git diff-index --quiet HEAD; then
            echo "No changes detected, skipping push."
          else
            # avoid leaking private commit hashes in the public repo
            git commit -m "sync($REPO_NAME): update from private repo"
            git push origin main
          fi
