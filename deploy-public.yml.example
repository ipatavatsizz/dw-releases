# SETUP (do this once per new project)
# ─────────────────────────────────────────────────────────────────
# 1. Create a Fine-grained PAT on GitHub:
#      Settings → Developer settings → Personal access tokens → Fine-grained tokens
#      Resource owner : ipatavatsizz
#      Repository     : ipatavatsizz/dw-releases (only)
#      Permission     : Contents → Read and write
#
# 2. Add secret to THIS private repo:
#      Settings → Secrets and variables → Actions → New repository secret
#      Name   : PUBLIC_REPO_PAT
#      Value  : <paste PAT from step 1>
#
# 3. Ensure these paths exist in your private repo (missing ones are skipped):
#      package.json  →  "version" field   (version source of truth)
#      README.md                           (→ dw-releases/<repo>/README.md)
#      assets/                             (→ dw-releases/<repo>/assets/)
#      release-notes/                      (→ dw-releases/<repo>/release-notes/)
# ─────────────────────────────────────────────────────────────────

name: Sync to dw-releases

on:
  push:
    branches:
      - main
    paths:
      - 'package.json' # versiyon değişikliği / version bump
      - 'release-notes/**'
      - 'assets/**'
  workflow_dispatch: # Manuel tetikleme / Manual trigger

env:
  REPO_NAME: ${{ github.event.repository.name }}
  RELEASES_REPO: ${{ github.repository_owner }}/dw-releases

jobs:
  sync:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Private Repo / Özel Repoyu Al
        uses: actions/checkout@v4
        with:
          path: private-repo

      - name: Checkout dw-releases / dw-releases Reposunu Al
        uses: actions/checkout@v4
        with:
          repository: ${{ env.RELEASES_REPO }}
          token: ${{ secrets.PUBLIC_REPO_PAT }}
          path: dw-releases

      - name: Check Version Change / Versiyon Değişikliğini Kontrol Et
        id: version_check
        run: |
          NEW_VERSION=$(jq -r '.version' private-repo/package.json)
          CURRENT_VERSION=$(cat dw-releases/$REPO_NAME/.version 2>/dev/null || echo "none")

          echo "New version / Yeni sürüm: $NEW_VERSION"
          echo "Current version / Mevcut sürüm: $CURRENT_VERSION"

          if [ "$NEW_VERSION" = "$CURRENT_VERSION" ]; then
            echo "Version unchanged, skipping sync. / Sürüm değişmedi, sync atlanıyor."
            echo "changed=false" >> $GITHUB_OUTPUT
          else
            echo "Version changed, proceeding. / Sürüm değişti, devam ediliyor."
            echo "changed=true" >> $GITHUB_OUTPUT
            echo "version=$NEW_VERSION" >> $GITHUB_OUTPUT
          fi

      - name: Sync Repo Contents / Repo İçeriklerini Senkronize Et
        if: steps.version_check.outputs.changed == 'true'
        run: |
          VERSION=${{ steps.version_check.outputs.version }}

          # Create folder structure / Klasör yapısını oluştur
          mkdir -p dw-releases/$REPO_NAME/assets
          mkdir -p dw-releases/$REPO_NAME/release-notes

          # Update .version / .version dosyasını güncelle
          echo $VERSION > dw-releases/$REPO_NAME/.version

          # Copy README.md / README.md kopyala
          cp private-repo/README.md dw-releases/$REPO_NAME/README.md || true

          # Copy assets/ for README images / assets/ kopyala (README resimleri için)
          cp -r private-repo/assets/* dw-releases/$REPO_NAME/assets/ || true

          # Copy release-notes/ / release-notes/ kopyala
          cp -r private-repo/release-notes/* dw-releases/$REPO_NAME/release-notes/ || true

      - name: Push Changes to dw-releases / Değişiklikleri dw-releases'e Gönder
        if: steps.version_check.outputs.changed == 'true'
        env:
          GITHUB_TOKEN: ${{ secrets.PUBLIC_REPO_PAT }}
        run: |
          cd dw-releases
          VERSION=${{ steps.version_check.outputs.version }}

          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"

          git add $REPO_NAME/

          if git diff-index --quiet HEAD; then
            echo "No changes detected, push cancelled. / Herhangi bir değişiklik bulunamadı, push iptal edildi."
          else
            git commit -m "sync($REPO_NAME): v$VERSION"
            git push origin main
            echo "Successfully pushed v$VERSION. / v$VERSION başarıyla gönderildi."
          fi
